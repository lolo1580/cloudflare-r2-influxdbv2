# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Optional: bucket name for per-bucket GraphQL metrics.
# For jurisdiction-restricted buckets, use the Cloudflare analytics name, e.g. eu_my-bucket.
CLOUDFLARE_R2_BUCKET=

# Set to 0 to skip the REST account storage endpoint. Useful when the token only has Account Analytics Read.
R2_ACCOUNT_STORAGE_METRICS=1

# InfluxDB v2
INFLUX_URL=http://localhost:8086
INFLUX_ORG=your_org
INFLUX_BUCKET=your_bucket
INFLUX_TOKEN=your_influx_token

# Query window for operations/storage GraphQL metrics.
R2_LOOKBACK_MINUTES=60

# Keep 0 for normal runs and systemd. Set to 1 only for a temporary manual test;
# DRY_RUN=1 prints line protocol but does not write anything to InfluxDB.
DRY_RUN=0
